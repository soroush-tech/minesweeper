{
  "name": "minesweeper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "Prosperity-3.0",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "dev": "pnpm --filter @minesweeper/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "tsc": "turbo run tsc",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "preview": "pnpm --filter @minesweeper/web preview",
    "deploy": "pnpm --filter @minesweeper/web deploy"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "prettier": "^3.2.5",
    "pretty-quick": "^4.0.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@11.5.1"
}
